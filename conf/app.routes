# microservice specific routes


POST        /user-answers                       uk.gov.hmrc.securitiestransferchargesaveandreturn.controllers.UserAnswersController.save()
GET         /user-answers/:submissionId         uk.gov.hmrc.securitiestransferchargesaveandreturn.controllers.UserAnswersController.retrieve(submissionId:uk.gov.hmrc.securitiestransferchargesaveandreturn.models.SubmissionId)
GET         /user-answers/search/by-user        uk.gov.hmrc.securitiestransferchargesaveandreturn.controllers.UserAnswersController.retrieveSubmissionIdsByUser(userId:String)
GET         /user-answers/search/by-group       uk.gov.hmrc.securitiestransferchargesaveandreturn.controllers.UserAnswersController.retrieveSubmissionIdsByGroup(groupId:String)

POST        /submission-id                      uk.gov.hmrc.securitiestransferchargesaveandreturn.controllers.SubmissionIdController.nextSubmissionId()
